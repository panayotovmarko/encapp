# System test for surface encoding
# Encodes raw input using surface mode
test {
    input {
        filepath: "fake_input"
        resolution: "640x480"
        framerate: 30
        pix_fmt: nv12
        playout_frames: 100
    }
    common {
        id: "system_test_surface_encode"
        description: "Verify surface encoding"
    }
    configure {
        bitrate: "500 kbps"
        framerate: 30
        i_frame_interval: 1
        surface: true
        encode: true
    }
}
