# System test for surface transcoding with internal demuxer
# Uses internal Java demuxer instead of Android MediaExtractor
test {
    input {
        filepath: "/tmp/akiyo_qcif.mp4"
    }
    common {
        id: "system_test_surface_transcode_internal_demuxer"
        description: "Verify surface transcoding with internal demuxer"
    }
    configure {
        bitrate: "200 kbps"
        surface: true
    }
    test_setup {
        internal_demuxer: true
    }
}
